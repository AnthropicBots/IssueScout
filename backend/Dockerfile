# =============================================================================
# IssueScout Backend Docker Image
# =============================================================================

FROM python:3.12-slim

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# -----------------------------------------------------------------------------
# System Dependencies
# -----------------------------------------------------------------------------

RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential && \
    rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# Copy Project
# -----------------------------------------------------------------------------

COPY . .

# -----------------------------------------------------------------------------
# Install Application
# -----------------------------------------------------------------------------

RUN pip install --upgrade pip && \
    pip install .

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

EXPOSE 8000

CMD [
    "uvicorn",
    "issuescout.main:app",
    "--host",
    "0.0.0.0",
    "--port",
    "8000"
]
